<mujoco model="flexcomp_pin">
  <!-- GATED (mjs.flexcomp_pin). A flexcomp <pin> pins vertices to the parent
       body (no dof); mjs_makeFlex exposes no pinid/pinrange/pingrid argument, so
       the mjSpec leg would build every vertex as a free dof -- a SILENT wrong
       model. Forced MjsPath must error loudly; Auto must fall back to XmlPath.
       See test_path_diff_gated.py. -->
  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1"/>
    <flexcomp name="cloth" type="grid" count="4 4 1" spacing="0.08 0.08 0.08"
              dim="2" radius="0.008" pos="0 0 1">
      <pin id="0 3"/>
    </flexcomp>
  </worldbody>
  <equality>
    <flexvert name="fv" flex="cloth"/>
  </equality>
</mujoco>
