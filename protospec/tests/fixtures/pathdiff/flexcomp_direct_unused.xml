<mujoco model="flexcomp_direct_unused">
  <!-- PARITY. type="direct" with an unreferenced point (id 4): mjCFlexcomp::Make
       compacts unused points and reindexes elements. BuildFlexcompMirror mirrors
       the reindex/compaction so vert counts and body naming match XmlPath. -->
  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1"/>
    <flexcomp name="sheet" type="direct" dim="2" radius="0.01" pos="0 0 1"
              point="0 0 0  0.2 0 0  0.2 0.2 0  0 0.2 0  0.5 0.5 0.5"
              element="0 1 2  0 2 3"/>
  </worldbody>
</mujoco>
