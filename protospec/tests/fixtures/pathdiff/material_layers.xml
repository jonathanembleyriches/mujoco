<mujoco model="material_layers">
  <!-- Covers: multi-layer materials -- <material><layer texture= role=/>
       children mapping textures to PBR roles. Exercises mat_texid role slots
       on both compile legs. -->
  <asset>
    <texture name="base_tex" type="2d" builtin="checker" width="32" height="32"
             rgb1="0.2 0.2 0.6" rgb2="0.7 0.7 0.9"/>
    <texture name="rough_tex" type="2d" builtin="flat" width="32" height="32"
             rgb1="0.5 0.5 0.5" rgb2="0.5 0.5 0.5"/>
    <material name="layered">
      <layer texture="base_tex" role="rgb"/>
      <layer texture="rough_tex" role="roughness"/>
    </material>
  </asset>
  <worldbody>
    <geom name="floor" type="plane" size="2 2 0.1" material="layered"/>
  </worldbody>
</mujoco>
